{
  "builds": [
    {
      "src": "cropmind-ai/public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "cropmind-ai/public/index.html"
    }
  ]
}
{
  "framework": "nextjs", 
  "buildCommand": "cd cropmind-ai && npm run build",
  "outputDirectory": "cropmind-ai/.next"
}
