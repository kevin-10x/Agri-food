{
  "version": 2,
  "builds": [
    {
      "src": "cropmind-ai/backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "cropmind-ai/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/predict",
      "dest": "cropmind-ai/backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "cropmind-ai/$1",
      "continue": true
    }
  ]
}
